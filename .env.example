# Agent Peer Bridge — copy to .env (or use web setup at :3848/setup)

# Role on this machine
PEER_ROLE=developer
# developer | designer

# Pairing (web setup หรือ make wizard จะเติมให้)
PEER_SHARED_TOKEN=
PEER_HOST=
PEER_PORT=3847
PEER_SETUP_PORT=3848
# PEER_OPEN_BROWSER=0   # ปิดเปิด browser อัตโนมัติตอน make start
PEER_PAIRING_MODE=host
# host | guest

# Agent — product + mode (cli | sdk | api)
AGENT_PRODUCT=cursor
AGENT_MODE=sdk

# Cursor SDK/API
CURSOR_API_KEY=
CURSOR_RUNTIME=local
CURSOR_MODEL=composer-2.5
# AGENT_HUB_PATH=/Users/you/Documents/Agent
# (optional — แพ็กเล็กไม่ต้องใส่; ใช้โฟลเดอร์ bridge เป็น cwd)
# AGENT_HUB_REPO_URL=https://gitlab.../Agent.git

# Claude API (when AGENT_PRODUCT=claude AGENT_MODE=api)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible / Codex (when AGENT_PRODUCT=codex AGENT_MODE=api)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# CLI overrides (when AGENT_MODE=cli)
AGENT_CLI_COMMAND=cursor
AGENT_CLI_ARGS=agent

# Cowork
PEER_COWORK_MAX_ROUNDS=20
PEER_COWORK_POLL_MS=3000

# DS showcase (hub: resolve from docs/workspaces.local.md via PEER_SHOWCASE_WORKSPACE)
PEER_SHOWCASE_WORKSPACE=mui-showcase
# SHOWCASE=/absolute/path/mui-showcase

# Cloudflare Tunnel (Host) — public URLs for Guest over internet (optional)
# PEER_PUBLIC_SETUP_URL=https://peer-setup.YOUR_DOMAIN
# PEER_PUBLIC_PEER_URL=https://peer-api.YOUR_DOMAIN

# Optional fallback: AGENT_FALLBACK_MODE=api AGENT_FALLBACK_PRODUCT=cursor
